{
  "name": "wasm-spice",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "prepare:spice": "node ./scripts/prepare-wasm-spice.mjs",
    "rebuild:spice": "node ./scripts/prepare-wasm-spice.mjs --force",
    "predev": "npm run prepare:spice",
    "dev": "vite",
    "prebuild": "npm run prepare:spice",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "pretest:e2e": "npm run prepare:spice",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.4.2",
    "@tanstack/react-query": "^5.90.11",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "three": "^0.181.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.181.0",
    "@vitejs/plugin-react": "^5.1.1",
    "typescript": "~5.9.3",
    "vite": "^7.2.4"
  }
}
